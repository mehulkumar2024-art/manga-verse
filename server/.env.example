# ===== CORE CONFIGURATION =====
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ===== APPWRITE (Primary Database) =====
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_api_key
APPWRITE_DATABASE_ID=mangaverse

# ===== FIREBASE (Auth & Fallback) =====
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ===== CLOUDINARY (Image Storage) =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== REDIS (Job Queue) =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== MONGODB (Legacy - Optional) =====
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster.mongodb.net/mangaverse

# ===== AI/ML SERVICES =====
# Panel Detection
PANEL_DETECTION_MODEL_URL=https://your-model-url.com/panel-detection-model.json
PANEL_DETECTION_CONFIDENCE_THRESHOLD=0.5

# Character Detection
CHARACTER_DETECTION_MODEL_URL=https://your-model-url.com/character-detection-model.json
CHARACTER_DETECTION_CONFIDENCE_THRESHOLD=0.4

# OCR
OCR_LANGUAGE=eng
OCR_CONFIDENCE_THRESHOLD=0.6

# Text-to-Speech Provider
TTS_PROVIDER=web-speech
# TTS_PROVIDER=elevenlabs (for premium option)

# ElevenLabs API (Optional - for premium TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_MALE_YOUNG=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_MALE_ADULT=G0FwyJnSFvxLYfpvSpOK
ELEVENLABS_VOICE_FEMALE_YOUNG=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_FEMALE_ADULT=G0FwyJnSFvxLYfpvSpOK

# Google Cloud Text-to-Speech (Optional)
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_API_KEY=your_google_api_key

# ===== LOGGING =====
LOG_LEVEL=debug
LOG_FILE=logs/mangaverse.log

